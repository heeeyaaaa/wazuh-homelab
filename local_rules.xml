  <rule id="100624" level="0">
    <if_sid>100524</if_sid>
    <field name="audit.exe">/var/ossec/bin/wazuh-syscheckd</field>
    <description>Suppress: FIM scanning shadow file</description>
  </rule>


  <rule id="100625" level="0">
    <if_sid>550,553</if_sid>
    <field name="syscheck.path">/etc/resolv.conf</field>
    <description>Suppress: resolv.conf changes (normal DHCP/DNS behavior)</description>
  </rule>

  <rule id="100626" level="0">
    <if_sid>100650</if_sid>
    <field name="audit.exe">/var/ossec/bin/wazuh-modulesd</field>
    <description>Suppress: wazuh-modulesd reading its own certs</description>
  </rule>


  <rule id="100627" level="4" overwrite="yes">
    <if_sid>550</if_sid>
